{
  "name": "@vuer-ai/tinyplay",
  "version": "0.1.0",
  "description": "Generalized m3u8 playlist engine — load any time-segmented data (JSONL, VTT, binary, video) with a shared timeline, prefetch, and pluggable decoders.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -p tsconfig.build.json",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vuer-ai/tinyplay.git"
  },
  "homepage": "https://github.com/vuer-ai/tinyplay",
  "bugs": {
    "url": "https://github.com/vuer-ai/tinyplay/issues"
  },
  "keywords": [
    "m3u8",
    "hls",
    "playlist",
    "timeline",
    "streaming",
    "segmented-data",
    "react",
    "player",
    "jsonl",
    "time-series",
    "robotics",
    "animation"
  ],
  "license": "MIT",
  "author": "vuer-ai",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "react-dom": { "optional": true }
  },
  "dependencies": {
    "hls.js": "^1.5.0",
    "lru-cache": "^11.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
